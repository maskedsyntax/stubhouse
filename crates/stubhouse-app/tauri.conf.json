{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StubHouse",
  "version": "0.1.0",
  "identifier": "dev.stubhouse.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../src-frontend/dist",
    "beforeDevCommand": {
      "cwd": "../../src-frontend",
      "script": "bun run dev"
    },
    "beforeBuildCommand": {
      "cwd": "../../src-frontend",
      "script": "bun run build"
    }
  },
  "app": {
    "windows": [
      {
        "title": "StubHouse",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
